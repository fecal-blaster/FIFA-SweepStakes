# Copy this to .env on the Unraid host (next to docker-compose.yml).
# Then: docker compose up -d --build

# --- Public URL (must match the Cloudflare-exposed hostname exactly) ---
NEXTAUTH_URL=https://fifa.your-domain.com
APP_URL=https://fifa.your-domain.com

# Generate with: openssl rand -base64 32
NEXTAUTH_SECRET=REPLACE_WITH_LONG_RANDOM_STRING

# --- First-boot admin (created idempotently by the entrypoint) ---
ADMIN_EMAIL=admin@your-domain.com
ADMIN_PASSWORD=CHANGE_ME_BEFORE_BOOT

# --- Postgres ---
POSTGRES_USER=fifa
POSTGRES_PASSWORD=CHANGE_ME_TOO
POSTGRES_DB=fifa_sweepstakes
# Host-port mapping for the db; leave 5433 unless something else uses it.
POSTGRES_PORT=5433

# --- App port on the Unraid LAN ---
APP_PORT=7672

# --- Football data provider ---
# Set to "football-data-org" with a real API key for live World Cup data,
# or leave as "mock" to demo without internet.
FOOTBALL_PROVIDER=football-data-org
FOOTBALL_DATA_API_KEY=
FOOTBALL_DEFAULT_COMPETITION=WC

TIMEZONE=Pacific/Auckland
