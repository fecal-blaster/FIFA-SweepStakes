# --- Database ---
DATABASE_URL="postgresql://fifa:fifa@localhost:5432/fifa_sweepstakes?schema=public"

# --- Auth (NextAuth) ---
# Generate with: openssl rand -base64 32
NEXTAUTH_SECRET="change-me-to-a-long-random-string"
NEXTAUTH_URL="http://localhost:3000"

# Initial admin (created on first migrate/seed)
ADMIN_EMAIL="admin@example.com"
ADMIN_PASSWORD="changeme"

# --- Football data provider ---
# Provider name: "football-data-org" (default) | "mock"
FOOTBALL_PROVIDER="football-data-org"
# Get a free key at https://www.football-data.org/client/register
FOOTBALL_DATA_API_KEY=""
# Default competition code (e.g. WC for FIFA World Cup, EC for Euro)
FOOTBALL_DEFAULT_COMPETITION="WC"

# --- App ---
APP_URL="http://localhost:3000"
TIMEZONE="Pacific/Auckland"
